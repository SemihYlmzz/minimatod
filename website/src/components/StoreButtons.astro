---
import { SITE } from '../consts';
---

<div class="flex flex-col items-center gap-3 sm:flex-row sm:flex-wrap sm:justify-center">
  <!-- Primary: open the web app -->
  <a
    href={SITE.webApp}
    class="inline-flex items-center gap-2.5 rounded-2xl bg-paper px-6 py-3.5 font-semibold text-ink transition hover:opacity-90"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M3 12h18"></path>
      <path d="M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"></path>
    </svg>
    Use in browser
  </a>

  <!-- App Store -->
  <a
    href={SITE.appStore}
    class="inline-flex items-center gap-3 rounded-2xl border border-white/20 px-5 py-3 text-paper transition hover:bg-white/5"
  >
    <svg width="22" height="22" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
      <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"></path>
    </svg>
    <span class="text-left leading-tight">
      <span class="block text-[11px] text-muted">Download on the</span>
      <span class="block text-base font-semibold">App Store</span>
    </span>
  </a>

  <!-- Google Play -->
  <a
    href={SITE.playStore}
    class="inline-flex items-center gap-3 rounded-2xl border border-white/20 px-5 py-3 text-paper transition hover:bg-white/5"
  >
    <svg width="20" height="20" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
      <path d="M47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm278.3 234.3-60.1-60.1L104.6 13l220.7 221.3zM104.6 499l160.6-161.2 60.1-60.1L104.6 499zm367.6-273.4-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.3-60.8z"></path>
    </svg>
    <span class="text-left leading-tight">
      <span class="block text-[11px] text-muted">Get it on</span>
      <span class="block text-base font-semibold">Google Play</span>
    </span>
  </a>
</div>
