---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const faqs = [
  {
    q: 'What is Minimatod?',
    a: 'A minimalist notes and to-do app. The twist: every note or task can contain more notes and tasks, nested as deeply as you want — so a single item can become a whole project.',
  },
  {
    q: 'How deep can I nest items?',
    a: 'There is no fixed limit. Open any note or task to add items inside it, then open those, and so on.',
  },
  {
    q: 'What is the difference between a note and a task?',
    a: 'A task can be checked off when done; a note is just text. Both can hold children, and each list keeps notes and tasks grouped separately.',
  },
  {
    q: 'Do I need an account?',
    a: 'No. Minimatod works fully offline and stores your data on your device, so you can start immediately without signing up.',
  },
  {
    q: 'Where is my data stored?',
    a: 'Locally on your device (and in your browser when you use the web app). Nothing is uploaded to a server.',
  },
  {
    q: 'Is there cloud sync between my devices?',
    a: 'Not yet. Sync across devices is planned for a future update. Today, each device keeps its own data.',
  },
  {
    q: 'Which platforms are supported?',
    a: 'iOS, Android, and any modern web browser. You can use the web app without installing anything.',
  },
  {
    q: 'How much does it cost?',
    a: 'Minimatod is free to start. Some advanced features may become a paid upgrade in the future.',
  },
];
---

<Base
  title="FAQ"
  description="Frequently asked questions about Minimatod — the minimalist nested notes & to-do app."
>
  <section class="mx-auto max-w-3xl px-5 py-20 sm:py-28">
    <h1 class="text-4xl font-extrabold tracking-tight">Frequently asked questions</h1>
    <p class="mt-4 text-muted">
      Can’t find your answer? <a href="/support" class="text-paper underline underline-offset-4">Contact support</a>.
    </p>

    <div class="mt-12 divide-y divide-white/10">
      {
        faqs.map((item) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-semibold">
              {item.q}
              <span class="text-muted transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 leading-relaxed text-muted">{item.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</Base>
