---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';
---

<Base
  title="Support"
  description="Get help with Minimatod — contact support, report a bug, or request a feature."
>
  <section class="mx-auto max-w-3xl px-5 py-20 sm:py-28">
    <h1 class="text-4xl font-extrabold tracking-tight">Support</h1>
    <p class="mt-4 text-lg text-muted">
      We’re happy to help. Reach out and we’ll get back to you.
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      <a
        href={`mailto:${SITE.supportEmail}?subject=Minimatod%20Support`}
        class="rounded-2xl border border-white/10 bg-ink-soft p-6 transition hover:border-white/20"
      >
        <h2 class="text-lg font-semibold">Email us</h2>
        <p class="mt-2 text-sm text-muted">{SITE.supportEmail}</p>
      </a>
      <a
        href="/faq"
        class="rounded-2xl border border-white/10 bg-ink-soft p-6 transition hover:border-white/20"
      >
        <h2 class="text-lg font-semibold">Read the FAQ</h2>
        <p class="mt-2 text-sm text-muted">Answers to the most common questions.</p>
      </a>
    </div>

    <div class="mt-10 rounded-2xl border border-white/10 p-6">
      <h2 class="text-lg font-semibold">Reporting a bug?</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        Please include your device and OS version, the app version, and the steps
        to reproduce the issue. Screenshots help a lot.
      </p>
    </div>
  </section>
</Base>
